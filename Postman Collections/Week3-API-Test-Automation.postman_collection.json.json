	"item": [
		{
			"name": "Happy Path",
			"item": [
				{
					"name": "POST - Create User",
					"event": [
						{
							"listen": "test",
							"script": {
								"id": "d2b2271e-d556-44f0-9853-7138ee4e1487",
								"exec": [
									"// Status code & status text (Created)\r",
									"pm.test(\"Status code is 201\", () => pm.response.to.have.status(201));\r",
									"pm.test(\"Status text is Created\", () => pm.expect(pm.response.status).to.eql(\"Created\"));\r",
									"\r",
									"// Body contains id\r",
									"let jsonData ={};\r",
									"try { jsonData = pm.response.json(); } catch(e) {}\r",
									"pm.test(\"Response has id\", () => pm.expect(jsonData).to.have.property(\"id\"));\r",
									"\r",
									"// Save id to environment for later requests\r",
									"if (jsonData && jsonData.id) {\r",
									"    pm.environment.set(\"user_id\", jsonData.id);\r",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"id": "e17d9b59-4478-4196-b51e-941903810691",
					"protocolProfileBehavior": {
						"disableBodyPruning": true
					},
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "x-api-key",
								"value": "reqres-free-v1",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n  \"name\": \"{{user_name}}\",\r\n  \"job\": \"{{user_job}}\"\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{base_url}}/api/users"
					},
					"response": []
